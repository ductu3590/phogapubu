# Supabase — lấy từ https://supabase.com/dashboard/project/_/settings/api
VITE_SUPABASE_URL=https://xxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGc...

# Zalo Mini App — lấy từ https://developers.zalo.me
VITE_ZALO_APP_ID=xxxxxxxxxx
APP_ID=xxxxxxxxxx
# ZMP_TOKEN lấy qua `npx zmp login` dưới tài khoản Zalo sở hữu app này
ZMP_TOKEN=

# Slug quán trong bảng `stores` (dùng làm mặc định khi mở app không có ?store= trên QR)
VITE_DEFAULT_STORE_SLUG=pho-ga-pubu

# Môi trường
VITE_APP_ENV=development
